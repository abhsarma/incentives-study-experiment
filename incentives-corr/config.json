        "qual-q-base": {
            "baseComponent": "summary", 
            "parameters": {"inc": "base"},
            "response": [{
                "id": "prolificId",
                "prompt": "",
                "required": false,
                "hidden": true,
                "paramCapture": "PROLIFIC_PID",
                "type": "reactive"
            }, {
                "id": "qual-strategy",
                "prompt": "Please describe the strategy that you used in determining which plot had a higher correlation",
                "required": true,
                "location": "belowStimulus",
                "type": "longText"
            }, {
                "id": "qual-incentive-freq",
                "prompt": "How often do you encounter surveys with performance-based bonuses?",
                "secondaryText": "Studies evaluating visualization, such as this one, sometimes include performance-based bonuses (for example, instead of a guaranteed amount of $3.5, you would have been paid a guaranteed amount of $1.5, and awarded a bonus of $0.05 for every correct response).",
                "required": true,
                "location": "belowStimulus",
                "type": "likert",
                "numItems": 5,
                "leftLabel": "Never",
                "rightLabel": "Very Often",
                "labelLocation": "inline"
            }, {
                "id": "qual-incentives-history",
                "prompt": "If you have encountered performance-based bonuses in surveys previously, what has been your experience with receiving such bonuses?",
                "secondaryText": "If you have not encountered performance-based bonuses in surveys, please write 'N/A' in the text box",
                "required": true,
                "location": "belowStimulus",
                "type": "longText"
            }, {
                "id": "qual-incentive-effect",
                "prompt": "If you would have been paid a guaranteed amount of $1.5 and awarded a bonus of $0.1 for every correct response (instead of the guaranteed amount of $3.5), how do you think your performance would have changed?",
                "required": true,
                "location": "belowStimulus",
                "type": "longText"
            }]
        },
